{
  "name": "TopStepNewPlatformKit",
  "version": "1.0.0-beta4",
  "summary": "TopStep 新平台核心库，集成设备连接与数据交互功能",
  "description": "TSNewPlatformKit is a new platform protocol developed by Topu company, which mainly connects users and devices, as well as data transmission and control",
  "homepage": "https://gitee.com/topstep/TopStepNewPlatformKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "rd@hetangsmart.com": "tengzhang@topstep-tech.com"
  },
  "source": {
    "git": "https://gitee.com/topstep/TopStepNewPlatformKit.git",
    "tag": "1.0.0-beta4"
  },
  "platforms": {
    "ios": "12.0"
  },
  "source_files": "TopStepNewPlatformKit/Classes/**/*.{h,m,mm,swift}",
  "vendored_frameworks": "SDK/Frameworks/h264encoder.framework",
  "vendored_libraries": "SDK/Frameworks/libTscCompressor.a",
  "preserve_paths": [
    "SDK/Frameworks/*.framework",
    "SDK/Frameworks/*.a"
  ],
  "pod_target_xcconfig": {
    "IPHONEOS_DEPLOYMENT_TARGET": "12.0",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++14",
    "CLANG_CXX_LIBRARY": "libc++",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64 x86_64 i386",
    "OTHER_LDFLAGS[sdk=iphoneos*]": "$(inherited) -framework \"h264encoder\" -l\"TscCompressor\"",
    "OTHER_LDFLAGS[sdk=iphonesimulator*]": "$(inherited)"
  },
  "user_target_xcconfig": {
    "IPHONEOS_DEPLOYMENT_TARGET": "12.0",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++14",
    "CLANG_CXX_LIBRARY": "libc++",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64 x86_64 i386"
  },
  "frameworks": [
    "UIKit",
    "MapKit"
  ],
  "dependencies": {
    "TopStepInterfaceKit": [

    ],
    "TopStepToolKit": [

    ],
    "TopStepBleMetaKit": [

    ]
  }
}
