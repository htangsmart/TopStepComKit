{
  "name": "TopStepPersimwearKit",
  "version": "1.0.0-beta3",
  "summary": "TopStepPersimwearKit 是对persimwearSDK的封装，主要用来转接persimwearKit",
  "description": "TopStepPersimwearKit 是对persimwearSDK的封装，主要用来转接persimwearSDK内部实现部分方法",
  "homepage": "https://gitee.com/topstep/TopStepPersimwearKit.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "rd@hetangsmart.com": "tengzhang@topstep-tech.com"
  },
  "source": {
    "git": "https://gitee.com/topstep/TopStepPersimwearKit.git",
    "tag": "1.0.0-beta3"
  },
  "platforms": {
    "ios": "12.0"
  },
  "source_files": "TopStepPersimwearKit/Classes/**/*",
  "libraries": [
    "c++",
    "z",
    "sqlite3",
    "bz2.1.0"
  ],
  "frameworks": [
    "Foundation",
    "UIKit",
    "CoreBluetooth"
  ],
  "vendored_frameworks": "SDK/Frameworks/persimwearSDK.framework",
  "resources": "SDK/Resources/WearApi.bundle",
  "static_framework": true,
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64",
    "VALID_ARCHS": "arm64",
    "IPHONEOS_DEPLOYMENT_TARGET": "12.0",
    "SWIFT_VERSION": "5.0",
    "BUILD_LIBRARY_FOR_DISTRIBUTION": "YES",
    "FRAMEWORK_SEARCH_PATHS": "$(PODS_ROOT)/../SDK/Frameworks"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64",
    "VALID_ARCHS": "arm64",
    "IPHONEOS_DEPLOYMENT_TARGET": "12.0",
    "BUILD_LIBRARY_FOR_DISTRIBUTION": "YES",
    "FRAMEWORK_SEARCH_PATHS": "$(PODS_ROOT)/../SDK/Frameworks"
  },
  "dependencies": {
    "ReactiveObjC": [

    ],
    "TopStepInterfaceKit": [

    ],
    "TopStepToolKit": [

    ]
  }
}
