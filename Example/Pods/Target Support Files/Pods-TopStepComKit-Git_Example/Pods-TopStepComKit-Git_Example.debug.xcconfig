ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf" "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary" "${PODS_CONFIGURATION_BUILD_DIR}/zipzap" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/ComKit" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/FitCoreImp" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/Foundation" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/NpkCoreImp" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/ComKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/FitCoreImp" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/Foundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/NpkCoreImp"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1 $(inherited) GPB_USE_PROTOBUF_FRAMEWORK_IMPORTS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf/Protobuf.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive/SSZipArchive.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary/iOSDFULibrary.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/zipzap/zipzap.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/NpkCoreImp" "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_LDFLAGS = $(inherited) -ObjC -l"TscCompressor" -l"iconv" -l"z" -framework "ABParTool" -framework "Accelerate" -framework "CoreBluetooth" -framework "CoreGraphics" -framework "FitCloudDFUKit" -framework "FitCloudKit" -framework "FitCloudNWFKit" -framework "FitCloudWFKit" -framework "Foundation" -framework "ImageIO" -framework "Protobuf" -framework "RTKLEFoundation" -framework "RTKLocalPlaybackSDK" -framework "RTKOTASDK" -framework "SSZipArchive" -framework "Security" -framework "TopStepBleMetaKit" -framework "TopStepComKit" -framework "TopStepFitKit" -framework "TopStepInterfaceKit" -framework "TopStepNewPlatformKit" -framework "TopStepToolKit" -framework "UIKit" -framework "ZIPFoundation" -framework "h264encoder" -framework "iOSDFULibrary" -framework "zipzap"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/Protobuf" "-F${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive" "-F${PODS_CONFIGURATION_BUILD_DIR}/TopStepComKit-Git" "-F${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary" "-F${PODS_CONFIGURATION_BUILD_DIR}/zipzap"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
