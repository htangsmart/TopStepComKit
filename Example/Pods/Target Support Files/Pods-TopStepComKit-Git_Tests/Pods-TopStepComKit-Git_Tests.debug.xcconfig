ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
BUILD_LIBRARY_FOR_DISTRIBUTION = YES
CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES = YES
CLANG_CXX_LANGUAGE_STANDARD = c++14
CLANG_CXX_LIBRARY = libc++
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
EXCLUDED_ARCHS[sdk=iphonesimulator*] = x86_64
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AFNetworking" "${PODS_CONFIGURATION_BUILD_DIR}/WCDB.swift" "${PODS_CONFIGURATION_BUILD_DIR}/WCDBOptimizedSQLCipher" "${PODS_ROOT}/../../../TopStepComKit/TopStepBudsKit/SDK" "${PODS_ROOT}/../../../TopStepComKit/TopStepFitKit/SDK/Frameworks" "${PODS_ROOT}/../../../TopStepComKit/TopStepNewPlatformKit/SDK/Frameworks" "${PODS_ROOT}/../../../TopStepComKit/TopStepPersimwearKit/SDK/Frameworks" "${PODS_ROOT}/iOSLogBrowserSDK/iOSLogBrowserSDK" "${PODS_ROOT}/onnxruntime-c" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/ABMate" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/Foundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/MltCloud" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/StarBurst" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Audio" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Foundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Log/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Log/XLFacility" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/ThirdParty/Lame" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/ThirdParty/MagicHelper" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/VoiceAssistant" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepFitKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/iOSLogBrowserSDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/onnxruntime-c" $(PODS_ROOT)/../SDK/Frameworks
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1 $(inherited) GPB_USE_PROTOBUF_FRAMEWORK_IMPORTS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AFNetworking/AFNetworking.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/WCDB.swift/WCDBSwift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/WCDBOptimizedSQLCipher/sqlcipher.framework/Headers" "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/GCDWebServer" "${PODS_ROOT}/Headers/Public/Protobuf" "${PODS_ROOT}/Headers/Public/ReactiveObjC" "${PODS_ROOT}/Headers/Public/SSZipArchive" "${PODS_ROOT}/Headers/Public/SocketRocket" "${PODS_ROOT}/Headers/Public/TopStepBleMetaKit" "${PODS_ROOT}/Headers/Public/TopStepBudsKit" "${PODS_ROOT}/Headers/Public/TopStepComKit" "${PODS_ROOT}/Headers/Public/TopStepFitKit" "${PODS_ROOT}/Headers/Public/TopStepInterfaceKit" "${PODS_ROOT}/Headers/Public/TopStepNewPlatformKit" "${PODS_ROOT}/Headers/Public/TopStepPersimwearKit" "${PODS_ROOT}/Headers/Public/TopStepToolKit" "${PODS_ROOT}/Headers/Public/XLFacility" "${PODS_ROOT}/Headers/Public/YYCache" "${PODS_ROOT}/Headers/Public/YYImage" "${PODS_ROOT}/Headers/Public/YYWebImage" "${PODS_ROOT}/Headers/Public/libogg" "${PODS_ROOT}/Headers/Public/libopus" "${PODS_ROOT}/Headers/Public/onnxruntime-c" "${PODS_ROOT}/Headers/Public/onnxruntime-objc" "${PODS_ROOT}/Headers/Public/zipzap" $(PODS_ROOT)/TopStepToolKit/TopStepToolKit/Classes/** $(SDKROOT)/usr/include "${PODS_ROOT}/libopus/silk"
IPHONEOS_DEPLOYMENT_TARGET = 12.0
LIBRARY_SEARCH_PATHS = $(inherited) "${DT_TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/Protobuf/Protobuf.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary/iOSDFULibrary.modulemap" -fmodule-map-file="${PODS_ROOT}/Headers/Public/SSZipArchive/SSZipArchive.modulemap" -fmodule-map-file="${PODS_ROOT}/Headers/Public/TopStepBudsKit/TopStepBudsKit.modulemap" -fmodule-map-file="${PODS_ROOT}/Headers/Public/TopStepInterfaceKit/TopStepInterfaceKit.modulemap"
OTHER_LDFLAGS = $(inherited) -l"bz2.1.0" -l"c++" -l"iconv" -l"icucore" -l"sqlite3" -l"z" -framework "ABParTool" -framework "AFNetworking" -framework "AVFoundation" -framework "Accelerate" -framework "AssetsLibrary" -framework "CFNetwork" -framework "CoreAudio" -framework "CoreBluetooth" -framework "CoreFoundation" -framework "CoreGraphics" -framework "CoreImage" -framework "CoreMedia" -framework "CoreVideo" -framework "Foundation" -framework "ImageIO" -framework "MapKit" -framework "MicrosoftCognitiveServicesSpeech" -framework "MobileCoreServices" -framework "QuartzCore" -framework "RTKLEFoundation" -framework "RTKLocalPlaybackSDK" -framework "RTKOTASDK" -framework "Security" -framework "UIKit" -framework "WCDBSwift" -framework "h264encoder" -framework "sqlcipher" -framework "ten_vad"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/Protobuf/Protobuf.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary/iOSDFULibrary.modulemap" -Xcc -fmodule-map-file="${PODS_ROOT}/Headers/Public/SSZipArchive/SSZipArchive.modulemap" -Xcc -fmodule-map-file="${PODS_ROOT}/Headers/Public/TopStepBudsKit/TopStepBudsKit.modulemap" -Xcc -fmodule-map-file="${PODS_ROOT}/Headers/Public/TopStepInterfaceKit/TopStepInterfaceKit.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
VALID_ARCHS = arm64
