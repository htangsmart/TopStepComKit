CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES = YES
CLANG_CXX_LANGUAGE_STANDARD = c++14
CLANG_CXX_LIBRARY = libc++
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
EXCLUDED_ARCHS[sdk=iphonesimulator*] = arm64 x86_64 i386
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf" "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepBleMetaKit" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepComKit" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepInterfaceKit" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepNewPlatformKit" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepToolKit" "${PODS_ROOT}/../../../TopStepComKit/TopStepNewPlatformKit/SDK/Frameworks"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1 $(inherited) GPB_USE_PROTOBUF_FRAMEWORK_IMPORTS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf/Protobuf.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive/SSZipArchive.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepBleMetaKit/TopStepBleMetaKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepComKit/TopStepComKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepInterfaceKit/TopStepInterfaceKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepNewPlatformKit/TopStepNewPlatformKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepToolKit/TopStepToolKit.framework/Headers" $(PODS_ROOT)/TopStepToolKit/TopStepToolKit/Classes/** $(SDKROOT)/usr/include
IPHONEOS_DEPLOYMENT_TARGET = 12.0
OTHER_LDFLAGS = $(inherited) -l"c++" -l"iconv" -l"z" -framework "CoreFoundation" -framework "CoreGraphics" -framework "CoreImage" -framework "CoreVideo" -framework "Foundation" -framework "MapKit" -framework "Protobuf" -framework "QuartzCore" -framework "SSZipArchive" -framework "Security" -framework "TopStepBleMetaKit" -framework "TopStepInterfaceKit" -framework "TopStepNewPlatformKit" -framework "TopStepToolKit" -framework "UIKit" -framework "h264encoder"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
