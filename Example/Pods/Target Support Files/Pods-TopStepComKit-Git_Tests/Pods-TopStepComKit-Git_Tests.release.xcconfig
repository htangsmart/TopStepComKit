CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf" "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/ComKit" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/FitCoreImp" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/Foundation" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/FwCoreImp" "${PODS_ROOT}/TopStepComKit-Git/TopStepComKit-Git/Classes/NpkCoreImp" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/ComKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/FitCoreImp" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/Foundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/FwCoreImp" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepComKit-Git/NpkCoreImp"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1 $(inherited) GPB_USE_PROTOBUF_FRAMEWORK_IMPORTS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Protobuf/Protobuf.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive/SSZipArchive.framework/Headers" "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/zipzap"
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary/iOSDFULibrary.modulemap"
OTHER_LDFLAGS = $(inherited) -l"bz2" -l"iconv" -l"sqlite3" -l"z" -framework "ABParTool" -framework "Accelerate" -framework "CoreBluetooth" -framework "CoreGraphics" -framework "Foundation" -framework "ImageIO" -framework "Protobuf" -framework "RTKLEFoundation" -framework "RTKLocalPlaybackSDK" -framework "RTKOTASDK" -framework "SSZipArchive" -framework "Security" -framework "TopStepBleMetaKit" -framework "TopStepInterfaceKit" -framework "TopStepNewPlatformKit" -framework "TopStepToolKit" -framework "UIKit" -framework "h264encoder"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation/ZIPFoundation.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary/iOSDFULibrary.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/TopStepComKit-Git" "${PODS_CONFIGURATION_BUILD_DIR}/ZIPFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/iOSDFULibrary"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
