BUILD_LIBRARY_FOR_DISTRIBUTION = YES
CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/TopStepBudsKit
DEFINES_MODULE = YES
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AFNetworking" "${PODS_CONFIGURATION_BUILD_DIR}/WCDB.swift" "${PODS_CONFIGURATION_BUILD_DIR}/WCDBOptimizedSQLCipher" "${PODS_ROOT}/../../../TopStepComKit/TopStepBudsKit/SDK" "${PODS_ROOT}/iOSLogBrowserSDK/iOSLogBrowserSDK" "${PODS_ROOT}/onnxruntime-c" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/ABMate" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/Foundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/MltCloud" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/AI/StarBurst" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Audio" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Foundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Log/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/Log/XLFacility" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/ThirdParty/Lame" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/ThirdParty/MagicHelper" "${PODS_XCFRAMEWORKS_BUILD_DIR}/TopStepBudsKit/VoiceAssistant" "${PODS_XCFRAMEWORKS_BUILD_DIR}/iOSLogBrowserSDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/onnxruntime-c" $(inherited) "${PODS_TARGET_SRCROOT}/SDK"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/Headers/Private" "${PODS_ROOT}/Headers/Private/TopStepBudsKit" "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/libogg" $(PODS_ROOT)/TopStepBudsKit/TopStepBudsKit/Classes/**
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift @executable_path/Frameworks @loader_path/Frameworks
LIBRARY_SEARCH_PATHS = $(inherited) "${DT_TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_ROOT}/Headers/Public/SSZipArchive/SSZipArchive.modulemap" -fmodule-map-file="${PODS_ROOT}/Headers/Public/TopStepInterfaceKit/TopStepInterfaceKit.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_DEVELOPMENT_LANGUAGE = ${DEVELOPMENT_LANGUAGE}
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/../../../TopStepComKit/TopStepBudsKit
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
SWIFT_OBJC_INTERFACE_HEADER_NAME = TopStepBudsKit-Swift.h
SWIFT_VERSION = 5.0
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
