BUILD_LIBRARY_FOR_DISTRIBUTION = YES
CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/TopStepInterfaceKit
DEFINES_MODULE = YES
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/SSZipArchive" "${PODS_CONFIGURATION_BUILD_DIR}/TopStepToolKit"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) $(PODS_ROOT)/TopStepInterfaceKit/TopStepInterfaceKit/Classes/**
OTHER_LDFLAGS = $(inherited) -framework "CoreFoundation" -framework "CoreGraphics" -framework "CoreImage" -framework "CoreVideo" -framework "Foundation" -framework "QuartzCore" -framework "TopStepToolKit" -framework "UIKit"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_DEVELOPMENT_LANGUAGE = ${DEVELOPMENT_LANGUAGE}
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/../../../TopStepComKit/TopStepInterfaceKit
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
SWIFT_COMPILATION_MODE = wholemodule
SWIFT_INCLUDE_PATHS = $(inherited) $(PODS_ROOT)/TopStepInterfaceKit/TopStepInterfaceKit/Classes/**
SWIFT_OBJC_INTERFACE_HEADER_NAME = TopStepInterfaceKit-Swift.h
SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_VERSION = 5.0
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
