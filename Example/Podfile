# 以下三个 pod 单独强制为动态 framework（对齐官方 AIBudsSDK-Demo 的 dynamic_frameworks 列表）。
# 共同原因：它们都是「静态时把标准符号导出到主二进制全局符号表」的库，与系统/他库同名符号冲突，
# 在 use_frameworks! :linkage => :static + -ObjC 下产生问题：
#   - AFNetworking：与 StarburstSdk.framework 内嵌的 AFNetworking → duplicate symbol（链接失败）。
#   - WCDBOptimizedSQLCipher（sqlcipher，源码编入主二进制，导出标准 sqlite3_* 符号）：
#     污染全局，使 Fit 侧 TSDatabase 的 sqlite3_prepare_v2/exec 误绑到 sqlcipher 而非系统 libsqlite3，
#     叠加 iOS18 libRPAC 对 sqlite3_exec 的 interpose（checkWalModeFromQuery）→ 运行时 assert 崩溃。
#   - WCDB.swift：依赖 WCDBOptimizedSQLCipher(C core)，链接方式须与其一致，故一并动态化。
# 动态化后各库符号进独立 dylib 命名空间，主二进制仅引用，污染/冲突消除。
dynamic_frameworks = ['AFNetworking', 'WCDB.swift', 'WCDBOptimizedSQLCipher']
pre_install do |installer|
  installer.pod_targets.each do |pod|
    if dynamic_frameworks.include?(pod.name)
      def pod.static_framework?
        false
      end
      def pod.build_type
        Pod::BuildType.dynamic_framework
      end
    end
  end
end
